    "# VisualQA India 🇮🇳\n",
    "### Multimodal Road Safety & Flood Severity Analyzer\n",
    "\n",
    "A Vision-Language AI system that takes any road or area image and:\n",
    "- Answers natural language questions about visual content using BLIP-2\n",
    "- Computes a **Road Safety Score (0–100)** via a custom reasoning layer\n",
    "- Classifies flood and infrastructure risk from image input alone\n",
    "- Serves results through an interactive Gradio web interface\n",
    "\n",
    "**Architecture:** ViT Vision Encoder → Q-Former → OPT-2.7B LLM → Keyword Reasoning Layer\n",
    "\n",
    "**Model:** [`Salesforce/blip2-opt-2.7b`](https://huggingface.co/Salesforce/blip2-opt-2.7b)\n",
    "\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Dependencies\n",
    "!pip install transformers accelerate pillow gradio -q"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from transformers import Blip2Processor, Blip2ForConditionalGeneration\n",
    "from PIL import Image\n",
    "import torch\n",
    "import numpy as np\n",
    "import gradio as gr\n",
    "\n",
    "MODEL_ID = \"Salesforce/blip2-opt-2.7b\"\n",
    "\n",
    "processor = Blip2Processor.from_pretrained(MODEL_ID)\n",
    "model = Blip2ForConditionalGeneration.from_pretrained(\n",
    "    MODEL_ID,\n",
    "    torch_dtype=torch.float16,\n",
    "    device_map=\"auto\"\n",
    ")\n",
    "\n",
    "print(f\"Model loaded on: {next(model.parameters()).device}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def ask_image(image: Image.Image, question: str) -> str:\n",
    "    \"\"\"\n",
    "    Visual Question Answering using BLIP-2.\n",
    "    Encodes image via ViT + Q-Former, generates answer via OPT-2.7B.\n",
    "    \"\"\"\n",
    "    inputs = processor(\n",
    "        images=image,\n",
    "        text=question,\n",
    "        return_tensors=\"pt\"\n",
    "    ).to(\"cuda\", torch.float16)\n",
    "\n",
    "    with torch.no_grad():\n",
    "        output = model.generate(\n",
    "            **inputs,\n",
    "            max_new_tokens=100,\n",
    "            num_beams=4,\n",
    "            temperature=0.7,\n",
    "            do_sample=False\n",
    "        )\n",
    "\n",
    "    return processor.decode(output[0], skip_special_tokens=True).strip()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Risk taxonomy for the scoring layer\n",
    "RISK_KEYWORDS = {\n",
    "    \"high\": [\n",
    "        \"pothole\", \"crack\", \"broken\", \"damaged\", \"flooded\", \"collapsed\",\n",
    "        \"destroyed\", \"washed\", \"debris\", \"hazard\", \"dangerous\", \"severe\",\n",
    "        \"submerged\", \"overflow\", \"landslide\", \"erosion\"\n",
    "    ],\n",
    "    \"medium\": [\n",
    "        \"worn\", \"uneven\", \"dirty\", \"puddle\", \"wet\", \"narrow\",\n",
    "        \"construction\", \"blocked\", \"crowded\", \"poor\", \"deteriorating\"\n",
    "    ],\n",
    "    \"low\": [\n",
    "        \"clear\", \"good\", \"smooth\", \"clean\", \"normal\", \"safe\",\n",
    "        \"dry\", \"open\", \"maintained\", \"paved\", \"well\"\n",
    "    ]\n",
    "}\n",
    "\n",
    "DIAGNOSTIC_QUESTIONS = [\n",
    "    \"Is there any road damage, potholes, or cracks visible?\",\n",
    "    \"Is this area flooded or waterlogged?\",\n",
    "    \"Are there any visible safety hazards or obstructions?\",\n",
    "    \"What is the overall condition of the road or infrastructure?\",\n",
    "    \"Is this area safe for vehicles and pedestrians?\"\n",
    "]\n",
    "\n",
    "\n",
    "def compute_safety_score(qa_pairs: list) -> dict:\n",
    "    \"\"\"\n",
    "    Keyword-based reasoning layer.\n",
    "    Maps VQA answers to a Safety Score (0-100) with severity classification.\n",
    "    \"\"\"\n",
    "    score = 100\n",
    "    flags = []\n",
    "    positive_signals = []\n",
    "\n",
    "    for question, answer in qa_pairs:\n",
    "        answer_lower = answer.lower()\n",
    "\n",
    "        for keyword in RISK_KEYWORDS[\"high\"]:\n",
    "            if keyword in answer_lower:\n",
    "                score -= 20\n",
    "                flags.append(f\"⚠️ High Risk: '{keyword}' detected — {answer}\")\n",
    "                break\n",
    "\n",
    "        for keyword in RISK_KEYWORDS[\"medium\"]:\n",
    "            if keyword in answer_lower:\n",
    "                score -= 10\n",
    "                flags.append(f\"🔶 Moderate Risk: '{keyword}' detected — {answer}\")\n",
    "                break\n",
    "\n",
    "        for keyword in RISK_KEYWORDS[\"low\"]:\n",
    "            if keyword in answer_lower:\n",
    "                positive_signals.append(f\"✅ '{keyword}' — {answer}\")\n",
    "                break\n",
    "\n",
    "    score = max(0, min(100, score))\n",
    "\n",
    "    if score >= 75:\n",
    "        severity = \"🟢 SAFE\"\n",
    "    elif score >= 45:\n",
    "        severity = \"🟡 MODERATE RISK\"\n",
    "    else:\n",
    "        severity = \"🔴 HIGH RISK\"\n",
    "\n",
    "    return {\n",
    "        \"score\": score,\n",
    "        \"severity\": severity,\n",
    "        \"flags\": flags,\n",
    "        \"positive_signals\": positive_signals\n",
    "    }\n",
    "\n",
    "\n",
    "def full_analysis(image: Image.Image) -> dict:\n",
    "    \"\"\"\n",
    "    Runs all 5 diagnostic questions on an image and returns\n",
    "    the full Safety Score report.\n",
    "    \"\"\"\n",
    "    qa_pairs = []\n",
    "    for question in DIAGNOSTIC_QUESTIONS:\n",
    "        answer = ask_image(image, question)\n",
    "        qa_pairs.append((question, answer))\n",
    "\n",
    "    result = compute_safety_score(qa_pairs)\n",
    "    result[\"qa_pairs\"] = qa_pairs\n",
    "    return result"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def analyze_road_image(image, custom_question):\n",
    "    if image is None:\n",
    "        return \"⚠️ Please upload an image.\", \"\"\n",
    "\n",
    "    pil_image = Image.fromarray(image.astype(np.uint8)).convert(\"RGB\")\n",
    "    result = full_analysis(pil_image)\n",
    "\n",
    "    qa_text = \"\".join(\n",
    "        f\"**Q:** {q}\\n**A:** {a}\\n\\n\"\n",
    "        for q, a in result[\"qa_pairs\"]\n",
    "    )\n",
    "\n",
    "    flags_text = \"\\n\".join(result[\"flags\"]) if result[\"flags\"] else \"✅ No major risks detected\"\n",
    "    positive_text = \"\\n\".join(result[\"positive_signals\"]) if result[\"positive_signals\"] else \"None\"\n",
    "\n",
    "    analysis_output = f\"\"\"## {result['severity']}\n",
    "# Safety Score: {result['score']} / 100\n",
    "\n",
    "---\n",
    "\n",
    "### 🚨 Risk Flags\n",
    "{flags_text}\n",
    "\n",
    "### ✅ Positive Signals\n",
    "{positive_text}\n",
    "\n",
    "---\n",
    "\n",
    "### 🔍 Diagnostic Q&A\n",
    "{qa_text}\"\"\"\n",
    "\n",
    "    custom_output = \"\"\n",
    "    if custom_question and custom_question.strip():\n",
    "        answer = ask_image(pil_image, custom_question.strip())\n",
    "        custom_output = f\"**Q:** {custom_question}\\n\\n**A:** {answer}\"\n",
    "\n",
    "    return analysis_output, custom_output\n",
    "\n",
    "\n",
    "with gr.Blocks(title=\"VisualQA India\", theme=gr.themes.Soft(primary_hue=\"blue\")) as demo:\n",
    "\n",
    "    gr.Markdown(\"\"\"\n",
    "    # 🛣️ VisualQA India\n",
    "    ### Multimodal Road Safety & Flood Severity Analyzer\n",
    "    Upload a road or area image. The model will analyze safety conditions and generate a score.\n",
    "    \"\"\")\n",
    "\n",
    "    with gr.Row():\n",
    "        with gr.Column():\n",
    "            image_input = gr.Image(label=\"Upload Image\", type=\"numpy\")\n",
    "            custom_question = gr.Textbox(\n",
    "                label=\"Ask a custom question (optional)\",\n",
    "                placeholder=\"e.g. Can heavy vehicles pass safely?\"\n",
    "            )\n",
    "            analyze_btn = gr.Button(\"Analyze\", variant=\"primary\")\n",
    "\n",
    "        with gr.Column():\n",
    "            analysis_output = gr.Markdown()\n",
    "            custom_output = gr.Markdown()\n",
    "\n",
    "    analyze_btn.click(\n",
    "        fn=analyze_road_image,\n",
    "        inputs=[image_input, custom_question],\n",
    "        outputs=[analysis_output, custom_output]\n",
    "    )\n",
    "\n",
    "demo.launch(share=True)"
   ]
  }
 ]
}"
